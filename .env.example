HOST=0.0.0.0
PORT=8787

# Pick one credentials mode:
# 1) Local file path
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# 2) Inline JSON
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

VERTEX_PROJECT_ID=
VERTEX_LOCATION=global
VERTEX_MODEL=gemini-3.1-pro-preview
VERTEX_EMBEDDING_MODEL=gemini-embedding-001
VERTEX_IMAGE_MODEL=imagen-4.0-generate-001
VERTEX_TTS_MODEL=gemini-3.1-flash-tts-preview
VERTEX_RERANK_MODEL=semantic-ranker-default@latest
TTS_LOCATION=global
TTS_LANGUAGE_CODE=
RERANK_LOCATION=global
DEFAULT_TEMPERATURE=
DEFAULT_TOP_P=
DEFAULT_TOP_K=
DEFAULT_MAX_OUTPUT_TOKENS=

# Optional Bearer key required by clients talking to this proxy.
OPENAI_API_KEY=change-me

# Password for the local admin web console.
ADMIN_PASSWORD=vertex-admin

# Logging and retry behavior
LOG_LEVEL=debug
MAX_FETCH_ATTEMPTS=2
FETCH_RETRY_DELAY_MS=500

# Optional outbound HTTP proxy for Google APIs. Examples:
# OUTBOUND_PROXY_URL=http://127.0.0.1:7890
# OUTBOUND_PROXY_URL=127.0.0.1:7890
OUTBOUND_PROXY_URL=

# Thought exposure
INCLUDE_THOUGHTS=true
ENABLE_STREAMING=true
THOUGHTS_MODE=reasoning_content
THINKING_BUDGET=1024
