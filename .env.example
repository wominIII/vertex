HOST=127.0.0.1
PORT=8787

# Pick one credentials mode:
# 1) Local file path
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# 2) Inline JSON
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

VERTEX_PROJECT_ID=
VERTEX_LOCATION=global
VERTEX_MODEL=gemini-3.1-pro-preview

# Optional Bearer key required by clients talking to this proxy.
OPENAI_API_KEY=change-me

# Optional aliases if some upstream client insists on non-Gemini names.
MODEL_ALIASES=

# Logging and retry behavior
LOG_LEVEL=debug
MAX_FETCH_ATTEMPTS=2
FETCH_RETRY_DELAY_MS=500

# Thought exposure
INCLUDE_THOUGHTS=true
THOUGHTS_MODE=reasoning_content
THINKING_BUDGET=1024
